---
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
    class?: string;
    style?: string;
}

const { class: className = "", style } = Astro.props;
---

<WidgetLayout
    name="访问统计"
    id="site-stats"
    class={className}
    style={style}
>
    <site-stats-widget>
        <div class="grid gap-2">
            <div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-50">
                    Today
                </div>
                <div class="mt-2 flex items-end justify-between gap-4">
                    <span class="text-sm text-75">今日访问次数</span>
                    <span
                        data-value="todayVisits"
                        class="text-xl font-bold tabular-nums text-90"
                    >
                        --
                    </span>
                </div>
            </div>

            <div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-50">
                    Total Views
                </div>
                <div class="mt-2 flex items-end justify-between gap-4">
                    <span class="text-sm text-75">总访问次数</span>
                    <span
                        data-value="totalVisits"
                        class="text-xl font-bold tabular-nums text-90"
                    >
                        --
                    </span>
                </div>
            </div>

            <div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-50">
                    Total Visitors
                </div>
                <div class="mt-2 flex items-end justify-between gap-4">
                    <span class="text-sm text-75">总访客数量</span>
                    <span
                        data-value="totalVisitors"
                        class="text-xl font-bold tabular-nums text-90"
                    >
                        --
                    </span>
                </div>
            </div>

            <div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-50">
                    Your Region
                </div>
                <div class="mt-2 flex items-center justify-between gap-4">
                    <span class="shrink-0 text-sm text-75">当前地区</span>
                    <span
                        data-value="visitorRegion"
                        class="flex min-w-0 flex-1 flex-wrap items-center justify-end gap-x-1.5 gap-y-0.5 text-right text-sm font-bold leading-snug text-90"
                        title="地区加载中"
                    >
                        <span
                            data-region-text
                            class="min-w-0 max-w-full whitespace-normal break-words"
                        >
                            --
                        </span>
                        <span
                            data-region-flag
                            class="relative hidden inline-flex h-3.5 w-5 shrink-0 items-center justify-center overflow-hidden rounded-[2px] bg-[var(--btn-regular-bg)] text-[0.65rem] font-bold uppercase leading-none text-75 ring-1 ring-black/10 dark:ring-white/15"
                            aria-hidden="true"
                        >
                            <img
                                data-region-flag-image
                                class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-150"
                                alt=""
                                decoding="async"
                                loading="eager"
                            />
                            <span
                                data-region-flag-fallback
                                class="relative z-[1]"
                            ></span>
                        </span>
                    </span>
                </div>
            </div>
        </div>

        <p
            data-status
            class="hidden px-1 pt-2 text-xs text-50"
            aria-live="polite"
        ></p>
    </site-stats-widget>
</WidgetLayout>

<script>
    // @ts-nocheck
    import {
        getSiteStatsController,
        trackSiteStatsPageView,
    } from "@lib/browser/site-stats";

    class SiteStatsWidget extends HTMLElement {
        disconnectListener = null;
        statusNode;

        connectedCallback() {
            this.statusNode = this.querySelector("[data-status]");

            const controller = getSiteStatsController();
            this.disconnectListener = controller.subscribe((snapshot) => {
                this.renderSnapshot(snapshot);
            });

            void trackSiteStatsPageView();
            void this.loadVisitorRegion();
        }

        disconnectedCallback() {
            this.disconnectListener?.();
        }

        renderSnapshot(snapshot) {
            if (snapshot.todayVisits !== null) {
                this.setValue("todayVisits", snapshot.todayVisits);
            }

            if (snapshot.totalVisits !== null) {
                this.setValue("totalVisits", snapshot.totalVisits);
            }

            if (snapshot.totalVisitors !== null) {
                this.setValue("totalVisitors", snapshot.totalVisitors);
            }

            this.setStatus(snapshot.error ?? "");
        }

        formatNumber(value) {
            return new Intl.NumberFormat(
                document.documentElement.lang || "zh-CN",
            ).format(value);
        }

        setValue(key, value) {
            this.setText(key, this.formatNumber(value));
        }

        async loadVisitorRegion() {
            const cacheKey = "dear-nikki-visitor-region-v5";
            const cachedRegion = this.getCachedJson(cacheKey);

            if (cachedRegion) {
                this.setVisitorRegion(cachedRegion);
            }

            try {
                const lookupUrl = new URL("https://ipwho.is/");
                lookupUrl.searchParams.set("lang", "zh-CN");
                lookupUrl.searchParams.set("_", String(Date.now()));

                const response = await fetch(lookupUrl, {
                    cache: "no-store",
                    credentials: "omit",
                    referrerPolicy: "no-referrer",
                });

                if (!response.ok) {
                    throw new Error(`Region lookup failed: ${response.status}`);
                }

                const data = await response.json();
                const region = this.formatVisitorRegion(data);

                this.setCachedJson(cacheKey, region);
                this.setVisitorRegion(region);
            } catch {
                if (!cachedRegion) {
                    this.setVisitorRegion({ text: "未知地区" });
                }
            }
        }

        formatVisitorRegion(data) {
            if (!data?.success) {
                return { text: "未知地区" };
            }

            const countryCode = this.formatCountryCode(
                data.country_code || data.country,
            );
            const city = this.formatPlaceName(data.city, countryCode);
            const regionParts = this.splitPlaceParts(data.region, countryCode);
            const country = this.formatPlaceName(
                this.formatCountryName(data.country, countryCode),
                countryCode,
            );
            const explicitFlagUrl = this.formatExplicitFlagUrl(data.flag?.img);
            const generatedFlagUrl = this.formatGeneratedFlagUrl(countryCode);
            const parts = this.uniquePlaceParts([city, ...regionParts, country]);

            const regionText = parts.length > 0 ? parts.join(" · ") : "未知地区";
            return {
                text: regionText,
                flagAlt: country ? `${country}国旗` : "国家旗帜",
                flagFallback: countryCode,
                flagUrl: explicitFlagUrl || generatedFlagUrl,
                fallbackFlagUrl: explicitFlagUrl ? generatedFlagUrl : "",
            };
        }

        formatCountryCode(countryCode) {
            const normalizedCode = String(countryCode || "")
                .trim()
                .toUpperCase();

            return /^[A-Z]{2}$/.test(normalizedCode) ? normalizedCode : "";
        }

        formatCountryName(country, countryCode) {
            const countryName = String(country || "").trim();
            return countryName.toUpperCase() === countryCode ? "" : countryName;
        }

        formatPlaceName(value, countryCode) {
            const place = String(value || "")
                .trim()
                .replace(/\s+/g, " ")
                .replace(/[。,.，、·]+$/g, "");

            if (!place) {
                return "";
            }

            const aliasKey = place
                .toLowerCase()
                .replace(/[.\s-]+/g, " ")
                .replace(/\s+/g, " ")
                .trim();
            const aliases = {
                HK: new Set([
                    "hong kong",
                    "hong kong sar",
                    "hong kong s a r",
                    "香港特别行政区",
                    "香港特別行政區",
                    "中国香港",
                    "中國香港",
                ]),
                MO: new Set([
                    "macau",
                    "macao",
                    "macau sar",
                    "macao sar",
                    "澳门特别行政区",
                    "澳門特別行政區",
                    "中国澳门",
                    "中國澳門",
                ]),
            };

            if (countryCode === "HK" && aliases.HK.has(aliasKey)) {
                return "香港";
            }

            if (countryCode === "MO" && aliases.MO.has(aliasKey)) {
                return "澳门";
            }

            return place;
        }

        splitPlaceParts(value, countryCode) {
            return String(value || "")
                .split(/[·,，、/]+/)
                .map((part) => this.formatPlaceName(part, countryCode))
                .filter(Boolean);
        }

        uniquePlaceParts(parts) {
            return parts.filter((part, index, uniqueParts) => {
                if (!part) {
                    return false;
                }

                const previousParts = uniqueParts.slice(0, index);
                return !previousParts.some((previousPart) =>
                    this.isSamePlace(previousPart, part),
                );
            });
        }

        isSamePlace(first, second) {
            const firstKey = this.normalizePlaceKey(first);
            const secondKey = this.normalizePlaceKey(second);

            if (!firstKey || !secondKey) {
                return false;
            }

            if (firstKey === secondKey) {
                return true;
            }

            const hasCjk = /[\u4e00-\u9fa5]/.test(`${firstKey}${secondKey}`);
            const minimumLength = hasCjk ? 2 : 4;
            const shorterLength = Math.min(firstKey.length, secondKey.length);

            return (
                shorterLength >= minimumLength &&
                (firstKey.includes(secondKey) || secondKey.includes(firstKey))
            );
        }

        normalizePlaceKey(value) {
            return String(value || "")
                .trim()
                .toLowerCase()
                .replace(/特别行政区|特別行政區/g, "")
                .replace(/[^\p{L}\p{N}\u4e00-\u9fa5]/gu, "");
        }

        formatExplicitFlagUrl(flagUrl) {
            return String(flagUrl || "").trim();
        }

        formatGeneratedFlagUrl(countryCode) {
            return countryCode
                ? `https://cdn.ipwhois.io/flags/${countryCode.toLowerCase()}.svg`
                : "";
        }

        getCachedValue(key) {
            try {
                return sessionStorage.getItem(key);
            } catch {
                return null;
            }
        }

        setCachedValue(key, value) {
            try {
                sessionStorage.setItem(key, value);
            } catch {
                // Some privacy settings disable storage; region display still works.
            }
        }

        getCachedJson(key) {
            const cachedValue = this.getCachedValue(key);
            if (!cachedValue) {
                return null;
            }

            try {
                const cachedRegion = JSON.parse(cachedValue);
                return cachedRegion?.text ? cachedRegion : null;
            } catch {
                return { text: cachedValue };
            }
        }

        setCachedJson(key, value) {
            this.setCachedValue(key, JSON.stringify(value));
        }

        setVisitorRegion(region) {
            const regionText = String(region?.text || "未知地区");
            const container = this.querySelector('[data-value="visitorRegion"]');
            const textNode = this.querySelector("[data-region-text]");
            const flagNode = this.querySelector("[data-region-flag]");
            const flagImageNode = this.querySelector("[data-region-flag-image]");
            const flagFallbackNode = this.querySelector(
                "[data-region-flag-fallback]",
            );

            if (container) {
                container.title = regionText;
            }

            if (textNode) {
                textNode.textContent = regionText;
            }

            if (!flagNode) {
                return;
            }

            if (region?.flagUrl && flagImageNode) {
                const fallbackFlagUrl = String(region.fallbackFlagUrl || "");

                flagNode.title = region.flagAlt || "";
                flagNode.classList.remove("hidden");

                if (flagFallbackNode) {
                    flagFallbackNode.textContent = region.flagFallback || "";
                    flagFallbackNode.classList.toggle(
                        "hidden",
                        !region.flagFallback,
                    );
                }

                flagImageNode.classList.remove("opacity-100");
                flagImageNode.classList.add("opacity-0");
                flagImageNode.onload = () => {
                    flagImageNode.classList.remove("opacity-0");
                    flagImageNode.classList.add("opacity-100");
                    flagFallbackNode?.classList.add("hidden");
                };
                flagImageNode.onerror = () => {
                    if (
                        fallbackFlagUrl &&
                        flagImageNode.dataset.triedFallback !== "true"
                    ) {
                        flagImageNode.dataset.triedFallback = "true";
                        flagImageNode.src = fallbackFlagUrl;
                        return;
                    }

                    flagImageNode.classList.remove("opacity-100");
                    flagImageNode.classList.add("opacity-0");

                    if (!flagFallbackNode?.textContent) {
                        flagNode.classList.add("hidden");
                    }
                };
                flagImageNode.dataset.triedFallback = "false";
                flagImageNode.removeAttribute("src");
                flagImageNode.src = region.flagUrl;
                return;
            }

            flagImageNode?.removeAttribute("src");
            flagImageNode?.classList.remove("opacity-100");
            flagImageNode?.classList.add("opacity-0");
            if (flagFallbackNode) {
                flagFallbackNode.textContent = "";
            }
            flagNode.removeAttribute("title");
            flagNode.classList.add("hidden");
        }

        setText(key, value) {
            if (key === "visitorRegion") {
                this.setVisitorRegion({ text: value });
                return;
            }

            const node = this.querySelector(`[data-value="${key}"]`);
            if (!node) {
                return;
            }

            node.textContent = value;
        }

        setStatus(message) {
            if (!this.statusNode) {
                return;
            }

            if (!message) {
                this.statusNode.textContent = "";
                this.statusNode.classList.add("hidden");
                return;
            }

            this.statusNode.textContent = message;
            this.statusNode.classList.remove("hidden");
        }
    }

    if (!customElements.get("site-stats-widget")) {
        customElements.define("site-stats-widget", SiteStatsWidget);
    }
</script>
