---
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
    class?: string;
    style?: string;
}

const { class: className = "", style } = Astro.props;
---

<WidgetLayout
    name="访问统计"
    id="site-stats"
    class={className}
    style={style}
>
    <site-stats-widget>
        <div class="grid gap-2">
            <div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-50">
                    Today
                </div>
                <div class="mt-2 flex items-end justify-between gap-4">
                    <span class="text-sm text-75">今日访问次数</span>
                    <span
                        data-value="todayVisits"
                        class="text-xl font-bold tabular-nums text-90"
                    >
                        --
                    </span>
                </div>
            </div>

            <div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-50">
                    Total Views
                </div>
                <div class="mt-2 flex items-end justify-between gap-4">
                    <span class="text-sm text-75">总访问次数</span>
                    <span
                        data-value="totalVisits"
                        class="text-xl font-bold tabular-nums text-90"
                    >
                        --
                    </span>
                </div>
            </div>

            <div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-50">
                    Total Visitors
                </div>
                <div class="mt-2 flex items-end justify-between gap-4">
                    <span class="text-sm text-75">总访客数量</span>
                    <span
                        data-value="totalVisitors"
                        class="text-xl font-bold tabular-nums text-90"
                    >
                        --
                    </span>
                </div>
            </div>

            <div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-50">
                    Your Region
                </div>
                <div class="mt-2 flex items-end justify-between gap-4">
                    <span class="text-sm text-75">当前地区</span>
                    <span
                        data-value="visitorRegion"
                        class="max-w-[9rem] truncate text-right text-sm font-bold text-90"
                    >
                        --
                    </span>
                </div>
            </div>
        </div>

        <p
            data-status
            class="hidden px-1 pt-2 text-xs text-50"
            aria-live="polite"
        ></p>
    </site-stats-widget>
</WidgetLayout>

<script>
    // @ts-nocheck
    import {
        getSiteStatsController,
        trackSiteStatsPageView,
    } from "@lib/browser/site-stats";

    class SiteStatsWidget extends HTMLElement {
        disconnectListener = null;
        statusNode;

        connectedCallback() {
            this.statusNode = this.querySelector("[data-status]");

            const controller = getSiteStatsController();
            this.disconnectListener = controller.subscribe((snapshot) => {
                this.renderSnapshot(snapshot);
            });

            void trackSiteStatsPageView();
            void this.loadVisitorRegion();
        }

        disconnectedCallback() {
            this.disconnectListener?.();
        }

        renderSnapshot(snapshot) {
            if (snapshot.todayVisits !== null) {
                this.setValue("todayVisits", snapshot.todayVisits);
            }

            if (snapshot.totalVisits !== null) {
                this.setValue("totalVisits", snapshot.totalVisits);
            }

            if (snapshot.totalVisitors !== null) {
                this.setValue("totalVisitors", snapshot.totalVisitors);
            }

            this.setStatus(snapshot.error ?? "");
        }

        formatNumber(value) {
            return new Intl.NumberFormat(
                document.documentElement.lang || "zh-CN",
            ).format(value);
        }

        setValue(key, value) {
            this.setText(key, this.formatNumber(value));
        }

        async loadVisitorRegion() {
            const cacheKey = "dear-nikki-visitor-region";
            const cachedRegion = this.getCachedValue(cacheKey);

            if (cachedRegion) {
                this.setText("visitorRegion", cachedRegion);
                return;
            }

            try {
                const response = await fetch("https://ipwho.is/?lang=zh-CN", {
                    cache: "no-store",
                    credentials: "omit",
                    referrerPolicy: "no-referrer",
                });

                if (!response.ok) {
                    throw new Error(`Region lookup failed: ${response.status}`);
                }

                const data = await response.json();
                const region = this.formatVisitorRegion(data);

                this.setCachedValue(cacheKey, region);
                this.setText("visitorRegion", region);
            } catch {
                this.setText("visitorRegion", "未知地区");
            }
        }

        formatVisitorRegion(data) {
            if (!data?.success) {
                return "未知地区";
            }

            const city = String(data.city || "").trim();
            const region = String(data.region || "").trim();
            const country = String(data.country || "").trim();
            const parts = [];

            if (city) {
                parts.push(city);
            }

            if (region && region !== city) {
                parts.push(region);
            }

            if (country && (!region || !region.includes(country))) {
                parts.push(country);
            }

            return parts.length > 0 ? parts.join(" · ") : "未知地区";
        }

        getCachedValue(key) {
            try {
                return sessionStorage.getItem(key);
            } catch {
                return null;
            }
        }

        setCachedValue(key, value) {
            try {
                sessionStorage.setItem(key, value);
            } catch {
                // Some privacy settings disable storage; region display still works.
            }
        }

        setText(key, value) {
            const node = this.querySelector(`[data-value="${key}"]`);
            if (!node) {
                return;
            }

            node.textContent = value;
        }

        setStatus(message) {
            if (!this.statusNode) {
                return;
            }

            if (!message) {
                this.statusNode.textContent = "";
                this.statusNode.classList.add("hidden");
                return;
            }

            this.statusNode.textContent = message;
            this.statusNode.classList.remove("hidden");
        }
    }

    if (!customElements.get("site-stats-widget")) {
        customElements.define("site-stats-widget", SiteStatsWidget);
    }
</script>
