---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
const nameFlags = [
    {
        src: url("/flags/argentina.svg"),
        alt: "阿根廷国旗",
    },
    {
        src: url("/flags/japan.svg"),
        alt: "日本国旗",
    },
];
---

<div class="card-base p-3">
    <a
        aria-label="Go to About Page"
        href={url("/about/")}
        class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95"
    >
        <div
            class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center"
        >
            <Icon
                name="fa6-regular:address-card"
                class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl"
            />
        </div>
        <ImageWrapper
            src={config.avatar || ""}
            alt="Profile Image of the Author"
            class="mx-auto lg:w-full h-full lg:mt-0"
        />
    </a>
    <div class="px-2">
        <div
            class="mb-1 flex items-center justify-center gap-2 text-center font-bold text-xl dark:text-neutral-50 transition"
        >
            <img
                src={nameFlags[0].src}
                alt={nameFlags[0].alt}
                width="24"
                height="16"
                class="h-4 w-6 flex-none rounded-[0.125rem] object-cover shadow-sm shadow-black/15"
                loading="lazy"
            />
            <span class="min-w-0 truncate">{config.name}</span>
            <img
                src={nameFlags[1].src}
                alt={nameFlags[1].alt}
                width="24"
                height="16"
                class="h-4 w-6 flex-none rounded-[0.125rem] object-cover shadow-sm shadow-black/15"
                loading="lazy"
            />
        </div>
        <div
            class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"
        >
        </div>
        <div class="text-center text-neutral-400 mb-2.5 transition">
            {config.bio}
        </div>
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {
                config.links.length > 1 &&
                    config.links.map((item) => (
                        <a
                            rel="me"
                            aria-label={item.name}
                            href={item.url}
                            target="_blank"
                            class="btn-regular rounded-lg h-10 w-10 active:scale-90"
                        >
                            <Icon name={item.icon} class="text-[1.5rem]" />
                        </a>
                    ))
            }
            {
                config.links.length == 1 && (
                    <a
                        rel="me"
                        aria-label={config.links[0].name}
                        href={config.links[0].url}
                        target="_blank"
                        class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95"
                    >
                        <Icon
                            name={config.links[0].icon}
                            class="text-[1.5rem]"
                        />
                        {config.links[0].name}
                    </a>
                )
            }
        </div>
    </div>
</div>
