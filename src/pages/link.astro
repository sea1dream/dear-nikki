---
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const friendsData = [
    {
        name: " きたがわまりん",
        url: "https://www.2rk.cc/detail/101vGqIbcE5sbJ1EQ0Ln?id=1",
        avatar: "https://images.steamusercontent.com/ugc/2362769341371317445/BD8E2AD582B9B24D516FD1B5D03E05C81A0509E9/?imw=5000&imh=5000&ima=fit&impolicy=Letterbox&imcolor=%23000000&letterbox=false",
        description: "❤",
    },

];
// ============================================
---

<MainGridLayout title={i18n(I18nKey.link)} description={i18n(I18nKey.link)}>
    <div
            class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
    >
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <h1 class="text-2xl font-bold mb-4 text-black dark:text-white">友情链接</h1>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {
                    friendsData.map((friend) => (
                            <a
                                    href={friend.url}
                                    target="_blank"
                                    class="group flex items-center p-4 rounded-lg bg-[var(--card-bg)] border border-black/5 dark:border-white/10 hover:bg-[var(--btn-plain-bg-hover)] transition-all duration-300 decoration-none no-underline"
                            >
                                <div class="flex-shrink-0 mr-4">
                                    <img
                                            src={friend.avatar}
                                            alt={friend.name}
                                            class="w-16 h-16 rounded-full object-cover border-2 border-white/20 group-hover:rotate-12 transition-transform duration-300"
                                    />
                                </div>

                                <div class="overflow-hidden">
                                    <h3 class="font-bold text-lg truncate group-hover:text-[var(--primary)] transition-colors">
                                        {friend.name}
                                    </h3>
                                    <p class="text-sm opacity-60 line-clamp-2 mt-1">
                                        {friend.description}
                                    </p>
                                </div>
                            </a>
                    ))
                }
            </div>
        </div>
    </div>
</MainGridLayout>